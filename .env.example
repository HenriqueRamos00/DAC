#PostgreSQL
POSTGRES_USER=postgres_user
POSTGRES_PASSWORD=postgres_bantads
POSTGRES_DB=bantads
POSTGRES_PORT=5432
DB_HOST=localhost

#MongoDB
MONGO_INITDB_DATABASE=bantads_auth
MONGO_PORT=27017

#RabbitMQ
RABBITMQ_DEFAULT_USER=bantads
RABBITMQ_DEFAULT_PASS=bantads
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_HOST=localhost

#MS Cliente
SERVER_PORT=8082

#API Gateway
GATEWAY_PORT=3000
CLIENTE_URL=http://ms-cliente:8082
AUTH_URL=http://ms-auth:8081
CONTA_URL=http://ms-conta:8083
GERENTE_URL=http://ms-gerente:8084
ADMIN_URL=http://ms-admin:8085

#Saga Messaging
SAGA_RABBITMQ_EXCHANGE=bantads.saga
SAGA_RABBITMQ_QUEUE_CLIENTE_APROVAR_COMMAND=cliente.aprovar.command
SAGA_RABBITMQ_ROUTING_KEY_CLIENTE_APROVAR_COMMAND=cliente.aprovar
SAGA_RABBITMQ_ROUTING_KEY_CLIENTE_APROVAR_SUCESSO=cliente.aprovado
SAGA_RABBITMQ_ROUTING_KEY_CLIENTE_APROVAR_FALHA=cliente.aprovacao.falhou
SAGA_RABBITMQ_QUEUE_CLIENTE_REJEITAR_COMMAND=cliente.rejeitar.command
SAGA_RABBITMQ_ROUTING_KEY_CLIENTE_REJEITAR_COMMAND=cliente.rejeitar
SAGA_RABBITMQ_ROUTING_KEY_CLIENTE_REJEITAR_SUCESSO=cliente.rejeitado
SAGA_RABBITMQ_ROUTING_KEY_CLIENTE_REJEITAR_FALHA=cliente.rejeicao.falhou

#Saga Inserir Gerente
SAGA_RABBITMQ_QUEUE_CONTA_CONSULTAR_GERENTE_MAIS_CONTAS_COMMAND=conta.consultar-gerente-mais-contas.command
SAGA_RABBITMQ_ROUTING_KEY_CONTA_CONSULTAR_GERENTE_MAIS_CONTAS_COMMAND=conta.consultar-gerente-mais-contas
SAGA_RABBITMQ_ROUTING_KEY_CONTA_CONSULTAR_GERENTE_MAIS_CONTAS_SUCESSO=conta.gerente-mais-contas-consultado
SAGA_RABBITMQ_ROUTING_KEY_CONTA_CONSULTAR_GERENTE_MAIS_CONTAS_FALHA=conta.consulta-gerente-mais-contas.falhou
SAGA_RABBITMQ_QUEUE_GERENTE_INSERIR_COMMAND=gerente.inserir.command
SAGA_RABBITMQ_ROUTING_KEY_GERENTE_INSERIR_COMMAND=gerente.inserir
SAGA_RABBITMQ_ROUTING_KEY_GERENTE_INSERIR_SUCESSO=gerente.inserido
SAGA_RABBITMQ_ROUTING_KEY_GERENTE_INSERIR_FALHA=gerente.insercao.falhou
SAGA_RABBITMQ_QUEUE_CONTA_ATRIBUIR_GERENTE_COMMAND=conta.atribuir-gerente.command
SAGA_RABBITMQ_ROUTING_KEY_CONTA_ATRIBUIR_GERENTE_COMMAND=conta.atribuir-gerente
SAGA_RABBITMQ_ROUTING_KEY_CONTA_ATRIBUIR_GERENTE_SUCESSO=conta.gerente-atribuido
SAGA_RABBITMQ_ROUTING_KEY_CONTA_ATRIBUIR_GERENTE_FALHA=conta.atribuicao-gerente.falhou

#Saga Service
SAGA_PORT=8086
SAGA_RABBITMQ_QUEUE_SAGA_INSERIR_GERENTE_RESPONSE=saga.inserir-gerente.response
